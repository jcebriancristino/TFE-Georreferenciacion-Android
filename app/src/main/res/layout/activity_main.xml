<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".view.MainActivity">

    <EditText
        android:id="@+id/editTextZone"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:hint="Zone"
        android:inputType="textCapCharacters"
        android:singleLine="true"
        android:maxLength="3"
        android:textAlignment="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/editTextX"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintTop_toBottomOf="@+id/btnImport"
        />

    <EditText
        android:id="@+id/editTextX"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="X"
        android:inputType="numberDecimal|numberSigned"
        android:singleLine="true"
        android:textAlignment="center"
        app:layout_constraintEnd_toStartOf="@+id/editTextY"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/editTextZone"
        app:layout_constraintTop_toBottomOf="@id/btnImport"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <EditText
        android:id="@+id/editTextY"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Y"
        android:inputType="numberDecimal|numberSigned"
        android:singleLine="true"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@id/editTextX"
        app:layout_constraintTop_toBottomOf="@+id/btnExport"
        android:layout_marginStart="8dp" />



    <Button
        android:id="@+id/mainButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/punto_de_control_0_4"
        android:textAlignment="center"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@+id/spinnerElement"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp" />
    <Spinner
        android:id="@+id/spinnerCoordinateFormat"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/editTextX"
        app:layout_constraintBottom_toTopOf="@+id/mainButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/spinnerElement"
        android:layout_marginStart="0dp"
        android:layout_marginTop="5dp" />

    <Spinner
        android:id="@+id/spinnerElement"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/editTextY"
        app:layout_constraintBottom_toTopOf="@+id/mainButton"
        app:layout_constraintStart_toEndOf="@+id/spinnerCoordinateFormat"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="5dp" />

    <Button
        android:id="@+id/btnImport"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Importar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnExport"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="8dp" />

    <Button
        android:id="@+id/btnExport"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Exportar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnImport"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp"
        android:layout_marginStart="8dp" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/mainButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="12dp">

        <!-- Imagen -->
        <ImageView
            android:id="@+id/imageViewMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#DDDDDD"
            android:contentDescription="Imagen georreferenciada"
            android:scaleType="fitCenter"
            />

        <!-- Overlay -->
        <com.cebrian.tfg.geotactical.view.OverlayView
            android:id="@+id/gcpOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reiniciar"
            android:textSize="12sp"
            android:padding="6dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>